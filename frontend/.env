# FlugFinder Iran – Umgebungsvariablen
# Kopiere diese Datei als .env und fülle die Werte aus.

# === SerpApi (Google Flights) ===
# Registrierung: https://serpapi.com/users/sign_up
# API Key findest du unter: https://serpapi.com/manage-api-key
SERPAPI_API_KEY=dein_serpapi_key_hier

# === Telegram Bot ===
# 1. In Telegram: @BotFather anschreiben → /newbot → Bot-Name wählen
# 2. Bot-Token kopieren
# 3. Chat-ID: Nachricht an deinen Bot senden, dann
#    https://api.telegram.org/bot<TOKEN>/getUpdates aufrufen
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=deine_chat_id_hier
